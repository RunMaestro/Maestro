#!/bin/sh

# Run repo-wide validation before allowing a push.
# This mirrors the main CI gate: prompts, repo-wide Prettier, type checks, ESLint, and tests.
#
# Skip validation when the push only DELETES refs (no new commits to validate).
# Git feeds ref updates on stdin as: <local ref> <local sha> <remote ref> <remote sha>
# For a deletion the local sha is all zeros, so there is nothing to lint or test.
z40=0000000000000000000000000000000000000000
only_deletes=1
saw_ref=0
while read -r local_ref local_sha remote_ref remote_sha; do
	[ -z "$local_ref$remote_ref" ] && continue
	saw_ref=1
	case "$local_sha" in
		"$z40" | "") : ;; # deletion, nothing to validate
		*) only_deletes=0 ;;
	esac
done

if [ "$saw_ref" -eq 1 ] && [ "$only_deletes" -eq 1 ]; then
	echo "[pre-push] Delete-only push detected; skipping validate:push."
	exit 0
fi

# Preflight: confirm the toolchain is actually linked before running validate:push.
# validate:push invokes prettier/tsc/eslint/vitest as bare commands resolved from
# node_modules/.bin. A package-manager install links those .bin shims LAST (after
# unpacking package dirs), so during an in-flight or interrupted install the package
# exists but its shim is briefly missing - the gate then dies with a cryptic
# "command not found" (exit 127) that reads like a broken push. This happens in the
# auto-managed worktrees whose node_modules is reconciled out from under a push.
# Turn that into an actionable message and stop before the confusing failure.
for bin in prettier tsc eslint vitest; do
	if [ ! -e "node_modules/.bin/$bin" ]; then
		echo "[pre-push] node_modules/.bin/$bin is missing - dependencies are not fully linked."
		echo "[pre-push] A node_modules install is likely in flight or was interrupted."
		echo "[pre-push] Run 'npm ci' (or wait for the worktree to settle), verify"
		echo "[pre-push] 'node_modules/.bin/prettier' resolves, then re-push."
		exit 1
	fi
done

npm run validate:push
